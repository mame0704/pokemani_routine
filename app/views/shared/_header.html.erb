<header class="w-full bg-white border-b border-base-300 shadow-sm">
  <div class="navbar max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[64px]">

    <div class="flex-1 min-w-0">
      <%= link_to root_path, class: "inline-flex items-center gap-2" do %>
        <span class="text-base sm:text-xl font-bold text-base-content tracking-tight hover:opacity-80 truncate">
          ポケマニルーティン💰
        </span>
      <% end %>
    </div>

    <div class="flex-none">
      <%# 子どもログイン画面では何も出さない %>
      <% unless controller_path.in?(["child_sessions", "tops", "devise/sessions"]) %>

        <%# child_role配下（子どもログイン後の画面）は「ペアコード解除（子どもログアウト）」 %>
        <% if controller_path.start_with?("child_role/") %>
          <%= link_to "ログアウト",
              child_session_path,
              data: { turbo_method: :delete },
              class: "btn btn-soft btn-neutral btn-sm sm:btn-md rounded-xl px-4 sm:px-6" %>

        <%# それ以外は親のDeviseログアウト %>
        <% else %>
          <%= link_to "ログアウト",
              destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "btn btn-soft btn-neutral btn-sm sm:btn-md rounded-xl px-4 sm:px-6" %>
        <% end %>

      <% end %>
    </div>

  </div>
</header>