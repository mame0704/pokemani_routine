<div class="min-h-screen bg-white px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto flex min-h-screen w-full max-w-md items-center justify-center">
    <div class="w-full rounded-[2rem] bg-sky-50 p-8 shadow-sm sm:p-10">
      <div class="mb-6 text-center">
        <h1 class="text-2xl font-bold text-black sm:text-3xl">
          こどもログイン
        </h1>
        <p class="mt-2 text-sm text-black/70">
          ペアコードを入力してログインします
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="mb-5 rounded-2xl bg-yellow-50 px-4 py-3 text-sm text-black shadow-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: child_session_path, method: :post, local: true do %>
        <div class="mb-5">
          <%= label_tag :pair_code, "ペアコード", class: "mb-2 block text-sm font-medium text-black" %>
          <%= text_field_tag :pair_code, nil,
                class: "w-full rounded-2xl border border-green-100 bg-white px-4 py-3 text-black placeholder:text-gray-400 focus:border-green-200 focus:outline-none",
                required: true,
                placeholder: "ペアコードを入力" %>
        </div>

        <div>
          <%= submit_tag "ログイン",
                class: "w-full rounded-2xl bg-yellow-100 px-4 py-3 text-sm font-medium text-black shadow-sm transition hover:bg-yellow-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>