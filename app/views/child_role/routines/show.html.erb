<div class="mx-auto w-full max-w-3xl px-4 py-6 sm:px-6 lg:px-8 bg-white text-black">

  <div class="mb-6">
    <%= link_to "← ルーティン一覧へ",
      child_role_routines_path,
      class: "inline-flex items-center rounded-2xl border border-yellow-200 bg-white px-4 py-2 text-sm font-medium text-black shadow-sm transition hover:bg-yellow-50" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-black sm:text-3xl">
      ルーティン実行
    </h1>
    <p class="mt-2 text-sm leading-relaxed text-black/70">
      ルーティンの内容を確認して実行してください。
    </p>
  </div>

  <div class="overflow-hidden rounded-3xl border border-green-100 bg-green-50 shadow-sm">

    <div class="p-5 sm:p-6">

      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0">
          <h2 class="text-lg font-bold text-black sm:text-xl break-words">
            <%= @routine.title %>
          </h2>
        </div>

        <div class="self-start rounded-2xl border border-green-100 bg-white px-3 py-2 text-xs font-medium text-black shadow-sm">
          実行日：<%= Date.current %>
        </div>
      </div>

      <% if @routine.items.present? %>
        <div class="mt-5 rounded-3xl border border-sky-100 bg-white p-4 shadow-sm">
          <p class="mb-2 text-sm font-bold text-black">項目</p>
          <ul class="list-disc space-y-1 pl-5 text-sm text-black">
            <% @routine.items.each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% today_execution = @routine.routine_executions.find_by(executed_on: Date.current) %>
      <% latest_approval = today_execution&.routine_approvals&.order(created_at: :desc)&.first %>

      <% executed_today =
          if today_execution.nil?
            false
          elsif today_execution.completed?
            true
          elsif latest_approval&.rejected?
            false
          else
            true
          end %>

      <div class="mt-5 flex flex-col gap-3">

        <%= form_with model: [@routine, @routine.routine_executions.build],
                      url: child_role_routine_routine_executions_path(@routine),
                      local: true do |f| %>

          <%= f.submit "ルーティン実行",
              class: "w-full rounded-2xl bg-yellow-100 px-5 py-3 text-sm font-bold text-black shadow-sm transition hover:bg-yellow-200 #{'cursor-not-allowed opacity-50' if executed_today}",
              disabled: executed_today %>

        <% end %>

        <% if today_execution&.completed? %>
          <p class="mt-2 text-center text-sm text-black">
            今日のルーティンは承認済みです ✅
          </p>

        <% elsif latest_approval&.rejected? %>
          <p class="mt-2 text-center text-sm text-black">
            差し戻しされました。もう一度実行してください。
          </p>

        <% elsif today_execution.present? %>
          <p class="mt-2 text-center text-sm text-black/70">
            現在、承認待ちです。
          </p>
        <% end %>

      </div>

    </div>
  </div>
</div>
