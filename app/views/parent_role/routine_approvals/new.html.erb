<div class="mx-auto w-full max-w-3xl px-4 py-6 sm:px-6 lg:px-8 bg-white text-black">

  <% child_for_routines = current_user.children.first %>

  <div class="mb-6">
    <% if child_for_routines.present? %>
      <%= link_to "← ルーティン一覧へ",
          parent_role_child_routines_path(child_for_routines),
          class: "inline-flex items-center rounded-2xl border border-yellow-200 bg-white px-4 py-2 text-sm font-medium text-black shadow-sm transition hover:bg-yellow-50" %>
    <% else %>
      <%= link_to "← 子どもを作成する",
          parent_role_children_path,
          class: "inline-flex items-center rounded-2xl border border-green-200 bg-white px-4 py-2 text-sm font-medium text-black shadow-sm transition hover:bg-green-50" %>
    <% end %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-black sm:text-3xl">
      ルーティン承認
    </h1>
    <p class="mt-2 text-sm text-gray-600">
      今日実行されたルーティンを確認して、承認または差し戻しを行います。
    </p>
  </div>

  <% if @routine_executions.empty? %>
    <div class="rounded-3xl border border-green-100 bg-green-50 p-5 shadow-sm">
      <p class="text-sm font-medium text-black">
        今日はまだ実行がありません。
      </p>
    </div>
  <% end %>

  <div class="mt-4 space-y-5">
    <% @routine_executions.each do |execution| %>
      <div class="overflow-hidden rounded-3xl border border-green-100 bg-green-50 shadow-sm">

        <div class="p-5 sm:p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="min-w-0">
              <h2 class="text-lg font-bold text-black sm:text-xl break-words">
                <%= execution.routine.title %>
              </h2>
              <p class="mt-1 text-sm text-black/70">
                <span class="font-semibold">子ども：</span>
                <%= execution.routine.child.name %>
              </p>
            </div>

            <div class="self-start rounded-2xl bg-white px-3 py-2 text-xs font-medium text-black shadow-sm border border-green-100">
              実行日：<%= execution.executed_on %>
            </div>
          </div>

          <% if execution.routine.items.present? %>
            <div class="mt-5 rounded-3xl bg-white p-4 shadow-sm border border-sky-100">
              <p class="mb-2 text-sm font-bold text-black">項目</p>
              <ul class="list-disc space-y-1 pl-5 text-sm text-black">
                <% Array(execution.routine.items).each do |item| %>
                  <li><%= item %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:justify-end">
            <%= form_with url: parent_role_routine_execution_routine_approvals_path(execution),
                          method: :post,
                          scope: :routine_approval,
                          class: "w-full sm:w-auto" do |f| %>
              <%= f.hidden_field :decision, value: "approved" %>
              <%= f.submit "承認する",
                  class: "w-full rounded-2xl bg-yellow-100 px-5 py-3 text-sm font-bold text-black shadow-sm transition hover:bg-yellow-200" %>
            <% end %>

            <%= form_with url: parent_role_routine_execution_routine_approvals_path(execution),
                          method: :post,
                          scope: :routine_approval,
                          class: "w-full sm:w-auto" do |f| %>
              <%= f.hidden_field :decision, value: "rejected" %>
              <%= f.submit "差し戻す",
                  class: "w-full rounded-2xl border border-yellow-200 bg-white px-5 py-3 text-sm font-bold text-black shadow-sm transition hover:bg-yellow-50" %>
            <% end %>
          </div>
        </div>

      </div>
    <% end %>
  </div>
</div>